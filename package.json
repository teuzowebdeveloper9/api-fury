    "@nestjs/swagger": "^11.4.4",
    "@scalar/nestjs-api-reference": "^1.1.16",
    "bullmq": "^5.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
